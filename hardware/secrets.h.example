// secrets.h — copy this to your Arduino project and fill in your own values.
// NEVER commit this file with real credentials. It's in .gitignore.

#ifndef SECRETS_H
#define SECRETS_H

// ── Wi-Fi ─────────────────────────────────────────────────────────────────
#define WIFI_SSID     "YourNetworkName"
#define WIFI_PASSWORD "YourPassword"

// ── Firebase Realtime Database ────────────────────────────────────────────
// Get these from Firebase Console → Project Settings → Service Accounts
#define DATABASE_URL    "https://your-project-default-rtdb.firebaseio.com/"
#define DATABASE_SECRET "your-database-secret-key-here"

#endif // SECRETS_H
